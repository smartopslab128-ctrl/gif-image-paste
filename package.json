{
  "name": "gif-image-paste-tool",
  "version": "0.1.0",
  "description": "Collect GIFs and images from anywhere, paste them anywhere. Always-on-top desktop tool.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.gifpaste.tool",
    "productName": "GIF & Image Paste",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
